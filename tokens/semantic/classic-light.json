{
  "surface": {
    "$value": "{color.paper.base}",
    "$type": "color"
  },
  "surface-raised": {
    "$value": "{color.paper.raised}",
    "$type": "color"
  },
  "surface-inverse": {
    "$value": "{color.plate.base}",
    "$type": "color"
  },
  "content": {
    "$value": "{color.ink.base}",
    "$type": "color"
  },
  "content-muted": {
    "$value": "{color.ink.soft}",
    "$type": "color"
  },
  "content-inverse": {
    "$value": "{color.paper.base}",
    "$type": "color"
  },
  "border": {
    "$value": "rgba(23, 21, 13, 0.18)",
    "$type": "color"
  },
  "accent": {
    "$value": "{color.nasa.cobalt}",
    "$type": "color"
  },
  "accent-expressive": {
    "$value": "{color.doppler.pink}",
    "$type": "color"
  },
  "accent-support": {
    "$value": "{color.report.green}",
    "$type": "color"
  },
  "accent-expressive-text": {
    "$value": "{content}",
    "$type": "color"
  },
  "accent-expressive-mark": {
    "$value": "{accent-expressive}",
    "$type": "color"
  },
  "on-accent-expressive": {
    "$value": "{color.ink.base}",
    "$type": "color"
  },
  "focus": {
    "$value": "{accent}",
    "$type": "color"
  },
  "shadow-print": {
    "$value": "4px 4px 0 rgba(23, 21, 13, 0.14)"
  },
  "shadow-print-lg": {
    "$value": "5px 5px 0 rgba(23, 21, 13, 0.12)"
  },
  "shadow-lift": {
    "$value": "5px 6px 0 rgba(23, 21, 13, 0.18)"
  },
  "shadow-sticky": {
    "$value": "2px 3px 0 rgba(23, 21, 13, 0.12)"
  },
  "shadow-sticky-lift": {
    "$value": "3px 5px 0 rgba(23, 21, 13, 0.16)"
  },
  "shadow-pin": {
    "$value": "0 2px 2px rgba(23, 21, 13, 0.3)"
  },
  "shadow-modal": {
    "$value": "0 18px 50px rgba(0, 0, 0, 0.45)"
  },
  "status": {
    "positive": {
      "base": {
        "$value": "{color.report.green}",
        "$type": "color"
      },
      "on-base": {
        "$value": "{color.paper.base}",
        "$type": "color"
      }
    },
    "warning": {
      "base": {
        "$value": "{color.amber.base}",
        "$type": "color"
      },
      "on-base": {
        "$value": "{color.paper.base}",
        "$type": "color"
      }
    },
    "danger": {
      "base": {
        "$value": "{color.blood.base}",
        "$type": "color"
      },
      "on-base": {
        "$value": "{color.paper.base}",
        "$type": "color"
      }
    },
    "info": {
      "base": {
        "$value": "{color.nasa.cobalt}",
        "$type": "color"
      },
      "on-base": {
        "$value": "{color.paper.base}",
        "$type": "color"
      }
    }
  },
  "interactive": {
    "default": {
      "base": {
        "$value": "transparent",
        "$type": "color"
      },
      "hover": {
        "$value": "rgba(231, 225, 210, 0.55)",
        "$type": "color",
        "$description": "baked from color-mix(in srgb, var(--surface) 55%, transparent) \u2014 re-derive if --surface changes"
      },
      "active": {
        "$value": "rgba(231, 225, 210, 0.7)",
        "$type": "color",
        "$description": "baked from color-mix(in srgb, var(--surface) 70%  [NEW: no :active existed in CSS], transparent) \u2014 re-derive if --surface changes"
      },
      "content-hover": {
        "$value": "{accent}",
        "$type": "color"
      }
    },
    "accent": {
      "base": {
        "$value": "{surface}",
        "$type": "color"
      },
      "hover": {
        "$value": "{accent}",
        "$type": "color"
      },
      "on-hover": {
        "$value": "{surface}",
        "$type": "color"
      }
    },
    "expressive": {
      "hover": {
        "$value": "{accent-expressive}",
        "$type": "color"
      },
      "on-hover": {
        "$value": "{on-accent-expressive}",
        "$type": "color"
      }
    },
    "disabled": {
      "opacity": {
        "$value": "0.55",
        "$description": "extracted from .projRow:disabled / .swatch:disabled"
      }
    }
  }
}
