  "type": {
    "$description": "Semantic type ramp v1 — role-named groups of plain size/leading/weight/tracking/family sub-tokens referencing core. Fluid roles (display, heading-1) carry clamp() literals to preserve the site's current responsive behavior. The Desktop/Mobile-mode round-trip representation of the fluid sizes, plus DTCG `typography` composites and Figma text-styles, land in the NEXT phase (do not build here).",
    "display": {
      "size": {
        "$value": "clamp(34px, 6vw, 62px)"
      },
      "leading": {
        "$value": "{leading.none}"
      },
      "weight": {
        "$value": "{weight.regular}"
      },
      "tracking": {
        "$value": "0"
      },
      "family": {
        "$value": "{display}"
      }
    },
    "heading-1": {
